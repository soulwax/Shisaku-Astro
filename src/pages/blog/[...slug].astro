---
import BaseHead from '../../components/BaseHead.astro';
import Comments from '../../components/Comments.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BlogPost from '../../layouts/BlogPost.astro';
import { listCommentsForPost } from '../../lib/comments';
import { getPublishedPostBySlug } from '../../lib/posts';
import { renderMarkdown } from '../../lib/markdown';

const slug = Astro.params.slug;
const post = slug ? await getPublishedPostBySlug(slug) : null;
const bodyHtml = post ? await renderMarkdown(post.bodyMarkdown) : '';
const comments = post ? await listCommentsForPost(post.id) : [];

if (!post) {
	Astro.response.status = 404;
}
---

{
	post ? (
		<BlogPost {...post}>
			<Fragment set:html={bodyHtml} />
			<Comments postId={post.id} comments={comments} user={Astro.locals.user} />
		</BlogPost>
	) : (
		<html lang="en">
			<head>
				<BaseHead title="Post not found · shisaku" description="The requested post was not found." />
			</head>
			<body>
				<Header />
				<main class="wrap auth-page">
					<div class="prompt">$ cat devlog/{slug}</div>
					<h1>Post not found</h1>
					<a class="button" href="/">Back to the feed</a>
				</main>
				<Footer />
			</body>
		</html>
	)
}
